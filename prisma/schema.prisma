generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Feed model - represents RSS/Atom feeds
model Feed {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String?
  link          String   @unique
  lastBuildDate String?
  language      String?
  generator     String?
  category      String?
  imageUrl      String?
  imageTitle    String?
  imageLink     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Embedded items (MongoDB approach)
  items FeedItem[]

  @@map("feeds")
}

// FeedItem model - represents individual articles/items in feeds
model FeedItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  link        String   @unique
  pubDate     String?
  guid        String?  @unique
  author      String?
  content     String?
  imageUrl    String?
  categories  String[] // Array of category names
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Reference to parent feed
  feedId String @db.ObjectId
  feed   Feed   @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@map("feed_items")
}